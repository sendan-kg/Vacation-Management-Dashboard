rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: pto_data
    // Document ID: employeeId (string)
    // Fields:
    //   - id: string (required)
    //   - name: string (required, max 100 chars)
    //   - department: string (required, max 100 chars)
    //   - grantDate: string (required, max 20 chars)
    //   - grantedDays: number (required, >= 0)
    //   - usedDays: number (required, >= 0)
    //
    // Collection: metadata
    // Document ID: system
    // Fields:
    //   - lastUpdated: string (required, max 50 chars)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "alwayshappys2.forever@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidEmployeeData(data) {
      return hasOnlyAllowedFields(['id', 'name', 'department', 'grantDate', 'grantedDays', 'usedDays']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.department is string && data.department.size() > 0 && data.department.size() < 100 &&
             data.grantDate is string && data.grantDate.size() > 0 && data.grantDate.size() < 20 &&
             data.grantedDays is number && data.grantedDays >= 0 &&
             data.usedDays is number && data.usedDays >= 0;
    }

    function isValidMetadata(data) {
      return hasOnlyAllowedFields(['lastUpdated']) &&
             data.lastUpdated is string && data.lastUpdated.size() > 0 && data.lastUpdated.size() < 50;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /pto_data/{employeeId} {
      // Anyone logged in can read
      allow read: if isAuthenticated();
      
      // Only admin can create/update/delete
      allow create: if isAdmin() && isValidEmployeeData(request.resource.data);
      allow update: if isAdmin() && isValidEmployeeData(request.resource.data);
      allow delete: if isAdmin();
    }

    match /metadata/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidMetadata(request.resource.data);
      allow update: if isAdmin() && isValidMetadata(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
